{
  "schema": "mcp_tool_schema_snapshot",
  "tools": [
    {
      "description": "Runs multiple Google Analytics reports in a single Data API batch request.",
      "inputSchema": {
        "$defs": {
          "BatchRunReportItemArgs": {
            "properties": {
              "currency_code": {
                "default": null,
                "type": [
                  "string",
                  "null"
                ]
              },
              "cursor": {
                "default": null,
                "description": "Opaque pagination cursor from `meta.next_cursor`.",
                "type": [
                  "string",
                  "null"
                ]
              },
              "date_ranges": {
                "items": {
                  "$ref": "#/$defs/ReportDateRangeSchema"
                },
                "type": "array"
              },
              "dimension_filter": {
                "default": null,
                "description": "GA FilterExpression. Accepts an object, JSON-object string, or `field==value` shorthand."
              },
              "dimensions": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "limit": {
                "default": null,
                "format": "uint64",
                "minimum": 0,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "max_cell_chars": {
                "default": null,
                "description": "Optional string clipping limit applied to response cell values.",
                "format": "uint",
                "minimum": 0,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "max_rows": {
                "default": null,
                "description": "Optional response row cap for Contract V1 tabular payloads.",
                "format": "uint",
                "minimum": 0,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "metric_filter": {
                "default": null,
                "description": "GA FilterExpression. Accepts an object or JSON-object string."
              },
              "metrics": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "offset": {
                "default": null,
                "format": "uint64",
                "minimum": 0,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "order_bys": {
                "default": null,
                "items": true,
                "type": [
                  "array",
                  "null"
                ]
              },
              "output_mode": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/TabularOutputMode"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Tabular output shape for the response payload."
              },
              "return_property_quota": {
                "default": true,
                "type": "boolean"
              },
              "summary_only": {
                "default": false,
                "description": "If true, omit row payload and return metadata only.",
                "type": "boolean"
              }
            },
            "required": [
              "date_ranges",
              "dimensions",
              "metrics"
            ],
            "type": "object"
          },
          "PropertyId": {
            "anyOf": [
              {
                "format": "uint64",
                "minimum": 0,
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          },
          "ReportDateRangeSchema": {
            "properties": {
              "end_date": {
                "description": "Inclusive end date (for example `2026-02-07`, `yesterday`).",
                "type": "string"
              },
              "start_date": {
                "description": "Inclusive start date (for example `2026-02-01`, `7daysAgo`).",
                "type": "string"
              }
            },
            "required": [
              "start_date",
              "end_date"
            ],
            "type": "object"
          },
          "TabularOutputMode": {
            "enum": [
              "rows",
              "tuples",
              "scalar",
              "compact"
            ],
            "type": "string"
          }
        },
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "property_id": {
            "$ref": "#/$defs/PropertyId"
          },
          "requests": {
            "items": {
              "$ref": "#/$defs/BatchRunReportItemArgs"
            },
            "type": "array"
          }
        },
        "required": [
          "property_id",
          "requests"
        ],
        "type": "object"
      },
      "name": "batch_run_reports"
    },
    {
      "description": "Preflights report dimensions/metrics via GA checkCompatibility and returns compatibility reason codes plus custom dimension/metric inventory.",
      "inputSchema": {
        "$defs": {
          "PropertyId": {
            "anyOf": [
              {
                "format": "uint64",
                "minimum": 0,
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "dimensions": {
            "description": "Requested dimensions for preflight compatibility checks.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "metrics": {
            "description": "Requested metrics for preflight compatibility checks.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "property_id": {
            "$ref": "#/$defs/PropertyId",
            "description": "The Google Analytics property id as integer or \"properties/<id>\"."
          }
        },
        "required": [
          "property_id",
          "dimensions",
          "metrics"
        ],
        "type": "object"
      },
      "name": "check_report_compatibility"
    },
    {
      "description": "Return copyable Google Analytics auth login commands, including direct browser OAuth when a client id file is supplied.",
      "inputSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "account": {
            "default": null,
            "description": "Optional Google account hint for browser login.",
            "type": [
              "string",
              "null"
            ]
          },
          "callback_port": {
            "default": null,
            "description": "Optional fixed loopback callback port for direct browser OAuth.",
            "format": "uint16",
            "maximum": 65535,
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "client_id_file": {
            "default": null,
            "description": "Optional Google OAuth client id file for direct browser OAuth.",
            "type": [
              "string",
              "null"
            ]
          },
          "headless": {
            "default": false,
            "description": "Include the headless browser flag for SSH or remote environments.",
            "type": "boolean"
          },
          "quota_project": {
            "default": null,
            "description": "Optional quota project to include as a follow-up command.",
            "type": [
              "string",
              "null"
            ]
          },
          "shared_adc": {
            "default": null,
            "description": "Use the conventional shared gcloud ADC file instead of the server-specific file.",
            "type": [
              "boolean",
              "null"
            ]
          }
        },
        "type": "object"
      },
      "name": "ga4_auth_login_command"
    },
    {
      "description": "Explain configured Google Analytics auth source and optionally verify Google API access without returning secrets.",
      "inputSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "verify_token": {
            "default": false,
            "description": "When true, verify the active GA4 credential path by calling account\nsummaries. In request_header mode, the caller must send the configured\nupstream token header. The token is never returned.",
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "name": "ga4_auth_status"
    },
